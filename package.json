    "dotenv": "^17.3.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "jose": "^6.2.0",
    "lucide-react": "^1.0.1",
    "mysql2": "^3.19.0",
    "next": "^15.5.12",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
