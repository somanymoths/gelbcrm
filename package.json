  "private": true,
  "scripts": {
    "dev": "node scripts/dev-safe.cjs",
    "dev:sandbox": "bash scripts/with-sandbox-env.sh npm run dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next-dev',{recursive:true,force:true})\" && NEXT_DIST_DIR=.next-dev next dev --turbopack",
    "task:new": "bash scripts/new-task-branch.sh",
    "task:start": "bash scripts/start-task.sh",
    "task:init": "bash scripts/task-init.sh",
    "task:summary": "bash scripts/task-summary.sh",
    "task:checkpoint": "bash scripts/task-checkpoint.sh",
    "task:review": "bash scripts/task-final-review.sh --run-checks",
    "ops:smoke": "bash scripts/ops-smoke.sh",
    "build": "node scripts/build-safe.cjs",
    "start": "next start",
    "deploy": "bash scripts/deploy.sh",
    "lint": "next lint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --incremental false",
    "db:migrate": "node scripts/migrate.cjs",
    "db:migrate:sandbox": "bash scripts/with-sandbox-env.sh node scripts/migrate.cjs",
    "db:seed:admin": "node scripts/seed-admin.cjs",
