    "react-dom": "19.0.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "19.0.11",
    "@types/react-dom": "19.0.4",
    "eslint": "9.21.0",
    "eslint-config-next": "^15.5.12",
